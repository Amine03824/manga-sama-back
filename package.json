  "main": "index.js",
  "scripts": {
    "start": "nodemon index.js",
    "dbr:create": "psql -d mangadb -U admin -h amine03824-server.eddi.cloud -p 5432 -W --set=sslmode=require -f data/SQL/create_tables.sql",
    "dbr:seed": "psql -d mangadb -U admin -h amine03824-server.eddi.cloud -p 5432 -W --set=sslmode=require -f data/SQL/seed_tables.sql",
    "dbr:reset": "psql -d mangadb -U admin -h amine03824-server.eddi.cloud -p 5432 -W --set=sslmode=require -f data/SQL/create_tables.sql && psql -d mangadb -U admin -h amine03824-server.eddi.cloud -p 5432 -W --set=sslmode=require -f data/SQL/seed_tables.sql",
    "test": "echo \"Error: no test specified\" && exit 1"
  }
